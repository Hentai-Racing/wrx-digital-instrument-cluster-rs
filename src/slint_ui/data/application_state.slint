import { SUnitSystem } from "../data/units.slint";

// TODO: move all settings to be auto-generated from `settings.rs` in a different `settings.slint` file

export global ApplicationState {
    in-out property <bool> debug-mode: true;

    in property <bool> virtual-cluster: true;

    in-out property <bool> simulation-running;
    callback update-simulation-running(bool);

    in-out property <SUnitSystem> user-unit;
    callback update-user-unit(SUnitSystem);

    in-out property <bool> settings-menu-visible: false;

    in-out property <bool> running-can: true;
    callback update-running-can(bool);

    in-out property <string> interface-type;
}

export global GeneralSettings {
    in-out property <bool> disable-hill-assist: false;
    callback update-disable-hill-assist(bool);
}

export global AccessibilitySettings {
    in-out property <bool> animations-enabled: true;
    callback update-animations-enabled(bool);

    in-out property <bool> accessible-switches: false;
    callback update-accessible-switches(bool);
}

export global DebugSettings {
    in-out property <bool> debug-highlights: false;
    callback update-debug-highlights(bool);

    in-out property <bool> debug-overlay-enabled: true;
    callback update-debug-overlay-enabled(bool);
}

export global HardwareBackendData {
    in-out property <int> adc-val;
    callback update-adc-val(int);

    in-out property <string> navigation-state;
    callback update-navigation-state(string);
}

export component ModuleDebug inherits VerticalLayout {
    Text {
        color: purple;
        text: "ApplicationState";
    }

    Text {
        color: white;
        text: "Units: " + (ApplicationState.user-unit == SUnitSystem.USCS ? "USCS" : "SI");
    }

    Text {
        color: white;
        text: "Settings visible: " + (ApplicationState.settings-menu-visible ? "true" : "false");
    }

    Text {
        color: purple;
        text: "AccessibilitySettings";
    }

    Text {
        color: white;
        text: "Animations: " + (AccessibilitySettings.animations-enabled ? "true" : "false");
    }

    Text {
        color: white;
        text: "Switches: " + (AccessibilitySettings.accessible-switches ? "alt" : "normal");
    }

    Text {
        color: purple;
        text: "DebugSettings";
    }

    Text {
        color: white;
        text: "Highlights: " + (DebugSettings.debug-highlights ? "true" : "false");
    }
}

export component BackendDebugModule inherits VerticalLayout {
    Text {
        color: darkviolet;
        text: "CanSettings";
    }

    Text {
        color: white;
        text: ApplicationState.virtual-cluster ? "virtual" : "normal";
    }

    if ApplicationState.virtual-cluster: Text {
        color: white;
        text: "Simulation: " + (ApplicationState.simulation-running ? "running" : "stopped");
    }

    Text {
        color: white;
        text: ApplicationState.interface-type;
    }

    Text {
        color: white;
        text: ApplicationState.running-can ? "running" : "halted";
    }

    Text {
        color: darkviolet;
        text: "HardwareBackendData";
    }

    Text {
        color: white;
        text: "ADC0: " + HardwareBackendData.adc-val;
    }

    Text {
        color: white;
        text: "Nav state: " + HardwareBackendData.navigation-state;
    }
}
