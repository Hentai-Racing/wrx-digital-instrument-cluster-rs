import {
    Button,
    FocusDomain,
    ComboBox,
    ToggleBox,
    DebugHighlight,
    FocusState,
} from "@lib/core.slint";
import { RSTypeResolver } from "@lib/rs.slint";
import { SBoundInt } from "@data/data_parameter.slint";
import {
    ApplicationState,
    AccessibilitySettings,
    DebugSettings,
    GeneralSettings,
} from "@lib/state.slint";
import { SUnitSystem } from "@lib/units.slint";
import { GlobalThemeData } from "@gen/themes/theme_loader_gen.slint";
import {
    ControlledFocusScope,
    Label,
    GlobalAnimation,
    Slider,
    GlobalSizing,
} from "../lib/core.slint";
import { AboutSlint } from "std-widgets.slint";

export enum SettingsMenuItemType {
    Parameter,
    ReadOnlyParameter,
    Page,
    PageBack,
    PageTitle,
}

export enum DerivedParamType {
    Enum,
    BoundInt,
    Number,
    String,
    Bool,
    Page,
    Trigger,
}

@rust-attr(derive(strum::VariantArray, serde::Serialize, serde::Deserialize))
export enum SettingsPageTarget {
    None,
    Attributions,
}

export struct SettingsMenuItem {
    name: string,
    param-path: string,
    param-type: string,
    param-type-derived: DerivedParamType,
    item-type: SettingsMenuItemType,
}

export global SettingsLayout {
    out property <SettingsPageTarget> special-page-target;

    public function trigger-special-page(page: SettingsPageTarget) {
        self.special-page-target = page;
    }

    public function exit-special-page() {
        self.special-page-target = SettingsPageTarget.None;
    }

    pure callback get-page-layout(path: string) -> [SettingsMenuItem];
    pure callback get-page-parent(path: string) -> string;
    pure callback get-by-path(path: string) -> string;
    pure callback set-by-path(path: string, val: string);
    pure callback stringify-derived-param-type(ty: DerivedParamType) -> string;
    pure callback get-bound-int(path: string) -> SBoundInt;
    pure callback get-bool(path: string) -> bool;
    pure callback get-settings-special-page(path: string) -> SettingsPageTarget;
    pure callback trigger-fn(path: string); // TODO: implement results
}

component DecorationBar inherits Rectangle {
    height: 2px;
    background: white;
    width: 100%;
}

component SettingBarLabel inherits Rectangle {
    in property <string> text <=> i-label.text;
    in property <bool> has-focus: false;

    private property <length> selector-x: self.has-focus ? 6px : 0;
    private property <length> label-x: self.has-focus ? 15px : 0;

    animate selector-x, label-x { duration: GlobalAnimation.standard-duration; }

    i-selection-indicator := Rectangle {
        x: 0;
        width: root.selector-x;
        height: 6px;
        border-radius: 3px;
        background: white;
    }

    i-label := Label {
        x: label-x;
        font-size: 20px;
        horizontal-alignment: left;
        vertical-alignment: center;
    }

    DebugHighlight { }
}

component SettingBar inherits Rectangle {
    in-out property <int> focus-id;

    in property <string> label <=> i-label.text;
    in property <bool> has-focus: FocusState.current-focus-id == self.focus-id;

    private property <length> i-padding: 15px;

    background: root.has-focus ? white.transparentize(90%) : transparent;
    border-radius: 6px;
    width: 600px;

    animate background { duration: GlobalAnimation.standard-duration; }

    VerticalLayout {
        alignment: center;
        padding: i-padding;

        HorizontalLayout {
            i-label := SettingBarLabel {
                has-focus: root.has-focus;
            }

            i-container := Rectangle {
                DebugHighlight {
                    background: blue;
                }

                HorizontalLayout {
                    spacing: 5px;
                    alignment: end;

                    @children
                }
            }
        }
    }

    DebugHighlight {
        background: yellow;
    }
}

component TypedSettingBar inherits SettingBar {
    in property <SettingsMenuItem> item;

    private property <bool> update-displayed-value: false;
    private property <bool> readonly: item.item-type == SettingsMenuItemType.ReadOnlyParameter;

    label: item.param-path;

    callback activated();

    if item.item-type == SettingsMenuItemType.ReadOnlyParameter: Rectangle {
        width: 0;
        height: 0;
        visible: false;

        Timer {
            interval: 25ms;
            running: true;
            triggered => {
                update-displayed-value = !update-displayed-value
            }
        }
    }

    if DebugSettings.debug-mode && DebugSettings.extra-debug-info: VerticalLayout {
        Text {
            color: tan;
            text: (readonly ? "readonly " : "") + SettingsLayout.stringify-derived-param-type(item.param-type-derived);
            horizontal-alignment: TextHorizontalAlignment.right;
        }

        Text {
            color: tan;
            text: item.param-type;
            horizontal-alignment: TextHorizontalAlignment.right;
        }

        Text {
            color: tan;
            text: item.param-path;
            horizontal-alignment: TextHorizontalAlignment.right;
        }
    }

    if item.param-type-derived == DerivedParamType.Bool: ToggleBox {
        locked: root.readonly;

        private property <bool> update <=> root.update-displayed-value;

        function update-current-value() {
            self.var = SettingsLayout.get-bool(item.param-path);
        }

        init-ready => {
            update-current-value();
            root.focus-id = self.focus-id;
        }

        toggled => {
            self.var = !self.var;
            SettingsLayout.set-by-path(item.param-path, RSTypeResolver.serialize-bool(self.var));
            root.activated();
        }

        changed update => update-current-value();
    }

    if item.param-type-derived == DerivedParamType.Enum: ComboBox {
        locked: root.readonly;
        title: root.label;
        model: RSTypeResolver.get-enum-variants(item.param-type);

        private property <bool> update <=> root.update-displayed-value;

        function update-current-value() {
            self.current-value = RSTypeResolver.dejsonify-str(SettingsLayout.get-by-path(item.param-path));
        }

        init-ready => {
            update-current-value();
            root.focus-id = self.focus-id;
        }

        selection-made => {
            SettingsLayout.set-by-path(item.param-path, RSTypeResolver.jsonify-str(self.current-value));
            root.activated();
        }

        changed update => update-current-value();
    }

    if item.param-type-derived == DerivedParamType.BoundInt: Slider {
        locked: root.readonly;
        title: root.label;
        current-value: bound.value;
        range-end: bound.end + 1;
        range-start: bound.start;
        step: bound.step != 0 ? bound.step : 1;

        private property <SBoundInt> bound: SettingsLayout.get-bound-int(item.param-path);
        private property <bool> update <=> root.update-displayed-value;

        function update-current-value() {
            self.bound = SettingsLayout.get-bound-int(item.param-path);
        }

        init-ready => {
            update-current-value();
            root.focus-id = self.focus-id;
        }

        changed current-value => {
            self.bound.value = self.current-value;
            SettingsLayout.set-by-path(item.param-path, RSTypeResolver.serialize-sboundint(self.bound));
            update-current-value();
        }

        changed update => update-current-value();
    }

    if (item.param-type-derived == DerivedParamType.Trigger): Rectangle {
        width: GlobalSizing.button-height;
        height: self.width;

        if item.param-type == "PageTrigger": Button {
            width: self.height;
            text: ">";

            init-ready => {
                root.focus-id = self.focus-id;
            }

            activated => {
                SettingsLayout.trigger-special-page(SettingsLayout.get-settings-special-page(item.param-path))
            }
        }

        if item.param-type == "FnTrigger": Button {
            width: self.height;
            text: "{>}";

            init-ready => {
                root.focus-id = self.focus-id;
            }

            activated => {
                SettingsLayout.trigger-fn(item.param-path);
            }
        }
    }

    // TODO: currently setting numbers & strings is not implemented
    if (item.param-type-derived == DerivedParamType.Number) || (item.param-type-derived == DerivedParamType.String): Button {
        width: 150px;
        locked: root.readonly;
        horizontal-alignment: TextHorizontalAlignment.right;

        private property <bool> update <=> root.update-displayed-value;

        function update-current-value() {
            self.text = RSTypeResolver.dejsonify-str(SettingsLayout.get-by-path(item.param-path));
        }

        init-ready => {
            update-current-value();
            root.focus-id = self.focus-id;
        }

        changed update => update-current-value();
    }

    if (item.item-type == SettingsMenuItemType.Page) || (item.item-type == SettingsMenuItemType.PageBack): Button {
        width: self.height;
        text: (item.item-type == SettingsMenuItemType.Page) ? ">" : "<";

        init-ready => {
            root.focus-id = self.focus-id;
        }

        activated => root.activated();
    }
}

component SettingsMenuLayoutComponent inherits VerticalLayout {
    alignment: center;
    spacing: 4px;

    out property <int> first-focus-id: -1;
    out property <int> last-focus-id;

    property <[SettingsMenuItem]> items;
    property <string> path: "Settings";
    property <string> parent-path: "Settings";

    function update-layout() {
        self.items = SettingsLayout.get-page-layout(self.path);
        self.parent-path = SettingsLayout.get-page-parent(self.path);
        FocusState.force-focus(self.first-focus-id);
    }

    init => update-layout();

    HorizontalLayout {
        alignment: center;

        VerticalLayout {
            spacing: 12px;

            page-title := TypedSettingBar {
                label: path;
                item: {
                    name: path,
                    param-path: root.path,
                    item-type: SettingsMenuItemType.PageTitle,
                    param-type-derived: DerivedParamType.Page,
                };
            }

            DecorationBar { }
        }
    }

    for item[i] in root.items: HorizontalLayout {
        alignment: center;

        function update-focus-ids(id: int) {
            if i == 0 {
                root.first-focus-id = id;
            }
        }

        if (item.item-type == SettingsMenuItemType.Parameter) || (item.item-type == SettingsMenuItemType.ReadOnlyParameter): TypedSettingBar {
            item: item;

            changed focus-id => update-focus-ids(self.focus-id);
        }
        if item.item-type == SettingsMenuItemType.Page: TypedSettingBar {
            item: item;

            changed focus-id => update-focus-ids(self.focus-id);

            activated => {
                root.path = item.param-path;
                root.update-layout();
            }
        }
    }

    page-back := TypedSettingBar {
        label: "Settings.page_back";

        item: {
            name: self.label,
            param-path: root.path,
            item-type: SettingsMenuItemType.PageBack,
            param-type-derived: DerivedParamType.Page,
        };

        changed focus-id => {
            root.last-focus-id = self.focus-id;
        }

        activated => {
            if (path == "") || (path == "Settings") {
                ApplicationState.settings-menu-visible = false;
            } else {
                root.path = root.parent-path;
            }

            root.update-layout();
        }
    }
}

component AttributionPage inherits FocusDomain {
    force-exit-strategy: false;
    force-focus: true;
    background: black;

    nav-front-forward => exit.focus();
    nav-end-backward => exit.focus();

    HorizontalLayout {
        alignment: center;
        VerticalLayout {
            alignment: center;
            spacing: 2px;

            HorizontalLayout {
                alignment: center;

                VerticalLayout {
                    alignment: center;
                    spacing: 12px;

                    page-title := TypedSettingBar {
                        label: "Settings.about.attributions";
                        item: {
                            name: self.label,
                            item-type: SettingsMenuItemType.PageTitle,
                            param-type-derived: DerivedParamType.Page,
                        };
                    }

                    DecorationBar { }

                    AboutSlint { }

                    TypedSettingBar {
                        label: "Settings.about.slint_version";
                        item: {
                            name: self.label,
                            param-path: self.label,
                            param-type: "String",
                            param-type-derived: DerivedParamType.String,
                            item-type: SettingsMenuItemType.ReadOnlyParameter,
                        };
                    }

                    DecorationBar { }

                    HorizontalLayout {
                        alignment: center;

                        exit := Button {
                            text: "Exit";

                            activated => root.exit-domain();
                            init => self.focus();
                        }
                    }
                }
            }
        }
    }
}

component SpecialPageLoader inherits Rectangle {
    background: transparent;

    HorizontalLayout {
        if SettingsLayout.special-page-target == SettingsPageTarget.Attributions: AttributionPage {
            exited => SettingsLayout.exit-special-page();
        }
    }
}

export component SettingsMenu inherits FocusDomain {
    force-exit-strategy: false;
    width: 2400px;
    height: 900px;

    nav-front-forward => FocusState.force-focus(layout.first-focus-id);
    nav-end-backward => FocusState.force-focus(layout.last-focus-id);

    if DebugSettings.debug-mode && DebugSettings.extra-debug-info: VerticalLayout {
        x: root.width - self.width;
        y: root.height - self.height;
        alignment: end;

        Text {
            color: white;
            text: layout.first-focus-id;
        }

        Text {
            color: white;
            text: layout.last-focus-id;
        }
    }

    HorizontalLayout {
        alignment: center;

        layout := SettingsMenuLayoutComponent {
            changed first-focus-id => {
                root.focus();
            }
        }
    }

    SpecialPageLoader {
        width: 100%;
        height: 100%;
    }
}
