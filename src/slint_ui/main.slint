import {
    ControlledFocusScope,
    FocusDomain,
    FocusHoverRect,
    ComboBoxSelectionBox,
    ComboBoxState,
    SliderSelectionBox,
    SliderState,
    LangResolver,
    BackendLib,
} from "@lib/core.slint";
import { RSTypeResolver } from "@lib/rs.slint";
import {
    DebugMenuWidget,
    DebugMenuState,
    DebugOverlay,
} from "@widgets/debug.slint";
import { SettingsMenu, SettingsPageTarget } from "@widgets/settings.slint";
import {
    SBoundInt,
    SFDataParameter,
    SIDataParameter,
    SBDataParameter,
    SStrDataParameter,
} from "@data/data_parameter.slint";
import { SCarData } from "@gen/data/car_data.slint";
import { SUnitSystem } from "@lib/units.slint";
import {
    ApplicationState,
    AccessibilitySettings,
    DebugSettings,
    GeneralSettings,
} from "@lib/state.slint";
import {
    ThemeLoader,
    GlobalThemeData,
    ClusterTheme,
} from "@gen/themes/theme_loader_gen.slint";
import { CanDisplay, SCanFrameDisplay } from "@widgets/can_display.slint";
import { WidgetContainerState } from "@widgets/widget_container.slint";
import {
    SettingsLayout,
    SettingsMenuItemType,
    SettingsMenuItem,
    DerivedParamType,
} from "@widgets/settings.slint";

// themes
import { DefaultTheme } from "@themes/default/default_main.slint";

// default fonts
import "@fonts/Montserrat/fonts/ttf/Montserrat-Black.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-Bold.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-ExtraLight.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-Light.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-Medium.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-Regular.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-SemiBold.ttf";
import "@fonts/Montserrat/fonts/ttf/Montserrat-Thin.ttf";

import "@fonts/JetBrainsMono/fonts/ttf/JetBrainsMono-Regular.ttf";

// Export types
export { SFDataParameter, SIDataParameter, SBDataParameter, SStrDataParameter, SUnitSystem, SCanFrameDisplay, SettingsMenuItemType, SettingsMenuItem, DerivedParamType, ClusterTheme, SBoundInt, SettingsPageTarget }
// Export globals
export { SCarData, DebugMenuState, GlobalThemeData, CanDisplay, WidgetContainerState, SettingsLayout, RSTypeResolver, LangResolver, BackendLib }
export * from "@lib/state.slint";

export component App inherits Window {
    default-font-family: "Montserrat";
    default-font-weight: 400;

    title: "WRX Digital Instrument Cluster";

    preferred-width: 2400px;
    preferred-height: 900px;

    background: black;

    // foreground
    // TODO: revert settings menu to appear as a "floating window"
    if ApplicationState.settings-menu-visible: settings-menu := SettingsMenu { }
    if !ApplicationState.settings-menu-visible: theme-loader := ThemeLoader { }

    // popup layer
        //*

    // popup highest layer
    // TODO: add single component that handles these singleton-popups
    if ComboBoxState.visible: ComboBoxSelectionBox { }
    if SliderState.visible: SliderSelectionBox { }

    // Highest layer
    FocusHoverRect { }

    // debug layer
    if (DebugSettings.debug-mode && DebugSettings.debug-overlay-enabled): DebugOverlay { }
}
