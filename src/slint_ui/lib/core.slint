    }

    Text {
        color: white;
        text: DomainState.last-domain-id;
    }

    Text {
        color: white;
        text: "pos {" + DomainState.focus-box.x / 1px + ", " + DomainState.focus-box.y / 1px + "}";
    }

    Text {
        color: white;
        text: "size {" + DomainState.focus-box.width / 1px + ", " + DomainState.focus-box.height / 1px + "}";
    }

    Text {
        color: red;
        text: DomainState.navigation-errors;
    }

    Text {
        color: purple;
        text: "ComboBoxState";
