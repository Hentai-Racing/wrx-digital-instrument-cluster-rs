        text: FocusState.force-focus-id + ": " + (FocusState.attempting-force-focus ? "true" : "false");
    }

    Text {
        color: orange;
        text: FocusState.failed-forces;
    }

    Text {
        color: purple;
        text: "DomainState";
    }

    Text {
        color: white;
