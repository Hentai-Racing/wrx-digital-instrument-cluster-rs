import { Notification } from "@lib/core.slint";
import { SCarData } from "@data/car_data.slint";

export component InteriorBrightnessIndicator {
    width: 350px;
    height: 60px;
    private property <string> dimmer_value: SCarData.dimmer_dial_value.value;

    private property <int> num-settings: 6;

    changed dimmer_value => {
        i-notification.restart()
    }

    i-notification := Notification {
        width: 100%;
        height: 100%;
        notify-on-init: true;

        Rectangle {
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    padding: 5px;

                    Image {
                        height: 50px;
                        width: 50px;
                        source: @image-url("@svg/interior-brightness-icon.svg");
                        colorize: white;

                        transform-rotation: dimmer_value.to-float() * (360deg / num-settings);
                        animate transform-rotation { // TODO: animation
                        duration: 100ms;
                            easing: Easing.ease-in-out-quad;
                        }
                    }

                    VerticalLayout {
                        alignment: center;

                        HorizontalLayout {
                            alignment: start;
                            spacing: 5px;
                            padding: 5px;
                            for rect[i] in num-settings: Rectangle {
                                width: 41px;
                                height: 7px;
                                border-radius: self.height / 2;
                                background: dimmer_value >= i ? white : white.darker(75%);
                            }
                        }
                    }
                }
            }
        }
    }
}
