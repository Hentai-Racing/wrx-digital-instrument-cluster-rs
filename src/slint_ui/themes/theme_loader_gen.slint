/// autogenerated from build.rs::generate_slint_themes()

//! See note in themes.slint

import { DebugTheme } from "debug/theme_main.slint";
import { DefaultTheme } from "default/theme_main.slint";

@rust-attr(derive(strum::VariantArray, strum::EnumString, strum::AsRefStr, serde::Serialize, serde::Deserialize))
export enum ClusterThemes {
	Debug,
	Default,
}

export global GlobalThemeData {
	in-out property <ClusterThemes> current-theme: ClusterThemes.Default;
	callback update_current_theme(ClusterThemes);
