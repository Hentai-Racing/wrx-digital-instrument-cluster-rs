// autogenerated from build.rs::generate_slint_themes()

//! See note in themes.slint

import { DebugTheme } from "debug/theme_main.slint";
import { DefaultTheme } from "default/theme_main.slint";
import { GlobalThemeData } from "themes.slint";

export component ThemeLoader {
	width: 100%;
	height: 100%;

	in-out property <[string]> themes: ["Debug", "Default"];

	init() => {
		GlobalThemeData.themes = self.themes;
	}

	if GlobalThemeData.current-theme == root.themes[0]: DebugTheme {width: 100%; height: 100%;}
	if GlobalThemeData.current-theme == root.themes[1]: DefaultTheme {width: 100%; height: 100%;}
}