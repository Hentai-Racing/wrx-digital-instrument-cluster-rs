import { ApplicationState, AccessibilitySettings, DebugSettings } from "../data/application_state.slint";
import { SUnitSystem } from "../data/units.slint";
import { ThemeSelectorWidget } from "../themes/themes.slint";
import { Button, FocusDomain, ComboBox, ToggleBox } from "core.slint";

export global UserSettings { } // TODO

component DecorationBar inherits Rectangle {
    height: 2px;
    background: white;
}

component SettingBarLabelTextBase inherits Text {
    horizontal-alignment: left;
    vertical-alignment: center;
}

component SettingBarLabelTextAnimated inherits SettingBarLabelTextBase {
    animate x { duration: 50ms; }
}

component SettingBarLabelText {
    in property <length> i-x;
    in property <string> text;
    if AccessibilitySettings.animations-enabled: SettingBarLabelTextAnimated {
        x: root.i-x;
        text: root.text;
    }
    if !AccessibilitySettings.animations-enabled: SettingBarLabelTextBase {
        x: root.i-x;
        text: root.text;
    }
}

component SettingsBarLabelBase {
    in property <string> text <=> i-label.text;
    in property <bool> has-focus: false;
    in-out property <length> selector-x: has-focus ? 6px : 0;

    i-selection-indicator := Rectangle {
        x: 0;
        width: root.selector-x;
        height: 6px;
        background: white;
    }

    i-label := SettingBarLabelText {
        x: 0;
        i-x: root.has-focus ? 10px : 0;
    }
}

component SettingsBarLabelBaseAnimated inherits SettingsBarLabelBase {
    animate selector-x { duration: 50ms; }
}

component SettingBarLabel inherits Rectangle {
    in property <string> text;
    in property <bool> has-focus: false;

    if AccessibilitySettings.animations-enabled: SettingsBarLabelBaseAnimated {
        x: 0;
        text: root.text;
        has-focus: root.has-focus;
    }
    if !AccessibilitySettings.animations-enabled: SettingsBarLabelBase {
        x: 0;
        text: root.text;
        has-focus: root.has-focus;
    }
}

component SettingBar inherits Rectangle {
    in property <string> label <=> i-label.text;
    in property <bool> has-focus <=> i-label.has-focus;

    property <length> i-padding: 5px;

    width: 250px;

    VerticalLayout {
        Rectangle {
            height: i-padding;
        }

        Rectangle {
            i-label := SettingBarLabel {
                x: i-padding;
            }

            VerticalLayout {
                i-container := HorizontalLayout {
                    spacing: 5px;
                    x: i-label.x + i-label.width;
                    width: parent.width - i-label.width - i-padding * 2;
                    alignment: end;

                    @children
                }
            }
        }

        Rectangle {
            height: i-padding;
        }
    }
}

export component SettingsMenu inherits FocusDomain {
    force-exit-strategy: false;

    nav-front-forward => theme-setting-widget.focus();
    nav-end-backward => exit-button.focus();

    // forward-focus: theme-setting-widget;

    init => {
        theme-setting-widget.focus();
    }

    VerticalLayout {
        alignment: center;
        spacing: 15px;

        theme-setting-widget := ThemeSelectorWidget {
            width: 100%;
            height: 30px;
        }

        SettingBar {
            label: "Units";

            has-focus: units-i-element.has-focus;
            units-i-element := ComboBox {
                model: ["USCS", "SI"];
                width: 100px;

                current-value: ApplicationState.user-unit == SUnitSystem.USCS ? "USCS" : "SI";

                changed current-value => {
                    ApplicationState.update-user-unit(self.current-value == "USCS" ? SUnitSystem.USCS : SUnitSystem.SI);
                }
            }
        }

        VerticalLayout {
            spacing: parent.spacing;
            alignment: parent.alignment;

            SettingBar {
                label: "Animations";
                has-focus: animations-i-element.has-focus;
                animations-i-element := ToggleBox {
                    var: AccessibilitySettings.animations-enabled;
                    toggled(val) => AccessibilitySettings.update-animations-enabled(val);
                }
            }

            SettingBar {
                label: "Alternate Switches";
                has-focus: accessible-switches-i-element.has-focus;
                accessible-switches-i-element := ToggleBox {
                    force-accessible-enaled: true;
                    var: AccessibilitySettings.accessible-switches;
                    toggled(val) => AccessibilitySettings.update-accessible-switches(val);
                }
            }
        }

        if ApplicationState.virtual_cluster: SettingBar {
            label: "Simulation Running: ";
            has-focus: simulation-toggle-i-element.has-focus;

            simulation-toggle-i-element := ToggleBox {
                var: ApplicationState.simulation-running;
                toggled(val) => ApplicationState.update_simulation_running(val);
            }
        }

        if ApplicationState.debug-mode: VerticalLayout {
            spacing: parent.spacing;
            alignment: parent.alignment;

            SettingBar {
                label: "Debug Highlights";
                has-focus: debug-highlights-i-element.has-focus;
                debug-highlights-i-element := ToggleBox {
                    var: DebugSettings.debug-highlights;
                    toggled(val) => DebugSettings.update-debug-highlights(val);
                }
            }

            SettingBar {
                label: "Debug Overlay";
                has-focus: debug-overlay-i-element.has-focus;
                debug-overlay-i-element := ToggleBox {
                    var: DebugSettings.debug-overlay-enabled;
                    toggled(val) => DebugSettings.update-debug-overlay-enabled(val);
                }
            }
        }

        HorizontalLayout {
            height: 30px;
            alignment: center;

            exit-button := Button {
                text: "Exit";

                activated => {
                    ApplicationState.settings-menu-visible = false;
                }
            }
        }
    }
}
