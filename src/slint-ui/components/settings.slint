import { ApplicationState, AccessibilitySettings } from "../data/application_state.slint";
import { SUnitSystem } from "../data/units.slint";
import { ThemeSelectorWidget } from "../themes/themes.slint";
import { Button, FocusDomain } from "core.slint";

export global UserSettings { } // TODO

export component SettingsMenu inherits FocusDomain {
    force-exit-strategy: false;

    nav-front-forward => theme-setting-widget.focus();
    nav-end-backward => exit-button.focus();

    forward-focus: theme-setting-widget;

    VerticalLayout {
        alignment: center;
        spacing: 15px;

        theme-setting-widget := ThemeSelectorWidget {
            width: 100%;
            height: 30px;
        }

        user-unit-setting := HorizontalLayout {
            height: 30px;
            alignment: center;
            padding: 2px;

            Text {
                vertical-alignment: center;
                text: "Units: ";
            }

            Button {
                text: ApplicationState.user-unit == SUnitSystem.USCS ? "USCS" : "SI";

                activated => {
                    ApplicationState.update_user_unit(ApplicationState.user_unit == SUnitSystem.USCS ? SUnitSystem.SI : SUnitSystem.USCS);
                }
            }
        }

        accessibility-animation-setting := HorizontalLayout {
            height: 30px;
            alignment: center;
            padding: 2px;

            Text {
                vertical-alignment: center;
                text: "Animations: ";
            }

            Button {
                text: AccessibilitySettings.animations-enabled ? "Enabled" : "Disabled";

                activated => AccessibilitySettings.update-animations-enabled(!AccessibilitySettings.animations-enabled);
            }
        }

        if ApplicationState.virtual_cluster: simulation-toggle-button := Rectangle {
            height: 30px;

            Button {
                text: "Toggle Simulation";

                activated => {
                    ApplicationState.toggle_simulation();
                }
            }
        }

        HorizontalLayout {
            height: 30px;
            alignment: center;

            exit-button := Button {
                text: "Exit";

                activated => {
                    ApplicationState.settings-menu-visible = false;
                }
            }
        }
    }
}
