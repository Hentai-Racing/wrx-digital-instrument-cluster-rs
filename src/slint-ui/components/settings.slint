import { ApplicationState, AccessibilitySettings, DebugSettings } from "../data/application_state.slint";
import { SUnitSystem } from "../data/units.slint";
import { ThemeSelectorWidget } from "../themes/themes.slint";
import { Button, FocusDomain, ComboBox } from "core.slint";

export global UserSettings { } // TODO

export component SettingsMenu inherits FocusDomain {
    force-exit-strategy: false;

    nav-front-forward => theme-setting-widget.focus();
    nav-end-backward => exit-button.focus();

    // forward-focus: theme-setting-widget;

    VerticalLayout {
        alignment: center;
        spacing: 15px;

        theme-setting-widget := ThemeSelectorWidget {
            width: 100%;
            height: 30px;
        }

        user-unit-setting := HorizontalLayout {
            height: 30px;
            alignment: center;
            padding: 2px;

            Text {
                vertical-alignment: center;
                text: "Units: ";
            }

            ComboBox {
                model: ["USCS", "SI"];
                width: 100px;

                current-value: ApplicationState.user-unit == SUnitSystem.USCS ? "USCS" : "SI";

                changed current-value => {
                    ApplicationState.update_user_unit(self.current-value == "USCS" ? SUnitSystem.USCS : SUnitSystem.SI);
                }
            }
        }

        accessibility-animation-setting := HorizontalLayout {
            height: 30px;
            alignment: center;
            padding: 2px;

            Text {
                vertical-alignment: center;
                text: "Animations: ";
            }

            Button {
                text: AccessibilitySettings.animations-enabled ? "Enabled" : "Disabled";

                activated => AccessibilitySettings.update-animations-enabled(!AccessibilitySettings.animations-enabled);
            }
        }

        if ApplicationState.virtual_cluster: simulation-toggle-button := Rectangle {
            height: 30px;

            Button {
                text: "Toggle Simulation";

                activated => {
                    ApplicationState.toggle_simulation();
                }
            }
        }

        if ApplicationState.debug-mode: VerticalLayout {
            spacing: parent.spacing;
            alignment: parent.alignment;

            HorizontalLayout {
                height: 30px;
                alignment: center;
                padding: 2px;

                Text {
                    vertical-alignment: center;
                    text: "Debug Highlights: ";
                }

                Button {
                    text: DebugSettings.debug-highlights ? "Enabled" : "Disabled";

                    activated => DebugSettings.update-debug-highlights(!DebugSettings.debug-highlights);
                }
            }

            HorizontalLayout {
                height: 30px;
                alignment: center;
                padding: 2px;

                Text {
                    vertical-alignment: center;
                    text: "Debug Overlay: ";
                }

                Button {
                    text: DebugSettings.debug-overlay-enabled ? "Enabled" : "Disabled";

                    activated => DebugSettings.update-debug-overlay-enabled(!DebugSettings.debug-overlay-enabled);
                }
            }
        }

        HorizontalLayout {
            height: 30px;
            alignment: center;

            exit-button := Button {
                text: "Exit";

                activated => {
                    ApplicationState.settings-menu-visible = false;
                }
            }
        }
    }
}
