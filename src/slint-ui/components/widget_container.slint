import { Button } from "std-widgets.slint";

import { DebugMenuWidget, DebugMenuState } from "debug.slint";
import { RoadIndicatorWidget } from "../themes/default/components/road_indicators.slint";
import { ThemeSelectorWidget } from "../themes/themes.slint";
import { ApplicationState } from "../application/application_state.slint";
import { NavigationMap } from "navmap.slint";


export component WidgetContainer inherits Rectangle {
    FocusScope {
        key-pressed(event) => {
            if ((event.text == Key.UpArrow) && (root.current-page < root.num-widgets - 1)) {
                root.current-page += 1;
            } else if ((event.text == Key.DownArrow) && (root.current-page > 0)) {
                root.current-page -= 1;
            }
            accept
        }
    }

    out property <length> buffer: 2.5px;

    in-out property <int> current-page: 0;
    out property <int> num-widgets: 5;

    function change-page(to-page: int) {
        current-page = to-page;
    }

    background: transparent;
    clip: true;

    in property <duration> page-animation-duration: 150ms;

    center-widget-container-indicator := Rectangle {
        width: parent.width;
        height: parent.height - center-widget-container-inner.height;

        y: 0;

        property <length> indicator-width: self.height;

        indicator-highlighter := Rectangle {
            background: purple;
            width: indicator-width;
            x: parent.width / 2 - indicator-layout.width / 2 + current-page * indicator-width;
            animate x {
                duration: page-animation-duration;
                easing: ease-in-out;
            }
        }

        indicator-layout := HorizontalLayout {
            x: parent.width / 2 - self.width / 2;
            width: num-widgets * indicator-width;

            for i in num-widgets: Rectangle {
                width: indicator-width;
                height: parent.height;
                background: transparent;

                Text {
                    text: i + 1;
                    color: white;
                }

                Button {
                    width: 100%;
                    height: 100%;
                    opacity: 0%;

                    clicked => {
                        change-page(i);
                    }
                }
            }
        }
    }

    center-widget-container-inner := Rectangle {
        width: 100%;
        height: 90%;

        y: parent.height - self.height;
        clip: true;

        center-widget-container-layout := HorizontalLayout {
            spacing: 10px;

            x: -root.current-page * root.width - self.spacing * current-page;
            animate x {
                duration: page-animation-duration;
                easing: ease-in-out;
            }

            road-indicator-widget := RoadIndicatorWidget {
                out property <int> widget-index: 0;
                height: 100%;
                width: 100%;
            }

            threed-container-image := Image {
                out property <int> widget-index: 1;
                height: 100%;
                width: 100%;
            }

            VerticalLayout {
                out property <int> widget-index: 2;

                padding: 20px;

                theme-setting-widget := ThemeSelectorWidget {
                    width: 100%;
                }

                Rectangle {
                    Button {
                        width: 100px;
                        height: 25px;
                        x: parent.width / 2 - self.width / 2;

                        text: "Toggle Settings";

                        clicked => {
                            ApplicationState.settings-menu-visible = !ApplicationState.settings-menu-visible;
                        }
                    }
                }
            }

            NavigationMap {
                out property <int> widget-index: 3;
                height: 100%;
                width: 100%;
            }

            DebugMenuWidget {
                out property <int> widget-index: 4;
                height: 100%;
                width: 100%;
            }
        }
    }
}
